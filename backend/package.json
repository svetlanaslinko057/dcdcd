{
  "name": "fomo-intelligence-api",
  "version": "2.0.0",
  "description": "FOMO Crypto Intelligence Platform - NestJS Backend",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "start:debug": "nest start --debug --watch",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "clean": "rm -rf dist",
    "rebuild": "npm run clean && npm run build",
    "health": "curl -s http://localhost:8001/api/health | python3 -m json.tool",
    "populate": "bash ../scripts/populate-data.sh",
    "graph:rebuild": "curl -X POST http://localhost:8001/api/graph/rebuild",
    "sync:dropstab": "curl -X POST http://localhost:8001/api/intel/dropstab/sync/all",
    "sync:news": "curl -X POST http://localhost:8001/api/news/sync/all"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/mongoose": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/schedule": "^6.1.1",
    "@types/uuid": "^10.0.0",
    "axios": "^1.13.6",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "mongoose": "^8.0.0",
    "puppeteer": "^22.0.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "reflect-metadata": "^0.1.13",
    "rss-parser": "^3.13.0",
    "rxjs": "^7.8.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@types/express": "^4.17.17",
    "@types/node": "^20.3.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.3"
  }
}
